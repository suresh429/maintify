<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31+) splash screen.
  windowSplashScreenBackground   — solid dark-navy fill
  windowSplashScreenAnimatedIcon — the M-logo vector drawable
  windowSplashScreenIconBackgroundColor — same dark-navy (removes the white circle)
-->
<resources>
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:forceDarkAllowed">false</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">false</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="android:windowSplashScreenBackground">#FFFFFF</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/android12splash</item>
        <item name="android:windowSplashScreenIconBackgroundColor">#FFFFFF</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@color/splash_background</item>
    </style>
</resources>
